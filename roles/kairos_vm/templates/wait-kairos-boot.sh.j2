#!/bin/bash
# Wait for Kairos to fully boot autonomously.
# Flow: empty disk → PXE fallback → BCM NFS boot (NOSYNC, no disk rsync) →
# initialize script runs install-kairos.sh → dd writes Kairos → sysrq reboot →
# GRUB-pc boots Kairos from MBR.
set -uo pipefail

BCM_HOST="{{ bcm_vm_ip }}"
BCM_PASSWORD="{{ bcm_password }}"
COMPUTE_MAC="{{ kairos_vm_mac }}"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"
SSH_CMD="sshpass -p ${BCM_PASSWORD} ssh ${SSH_OPTS} root@${BCM_HOST}"

TIMEOUT=1800
ELAPSED=0

echo "Waiting for autonomous Kairos boot (PXE → NFS boot → dd → Kairos)..."

while [ $ELAPSED -lt $TIMEOUT ]; do
  NODE_STATUS=$(${SSH_CMD} "echo -e 'device\nlist' | cmsh 2>/dev/null | grep -i '${COMPUTE_MAC}'" 2>/dev/null | tr -s ' ')

  # Check if Kairos has booted (look for /etc/kairos-release via SSH through BCM)
  KAIROS_IP=$(${SSH_CMD} "arp -an 2>/dev/null | grep -i '${COMPUTE_MAC}' | grep -oP '\d+\.\d+\.\d+\.\d+'" 2>/dev/null || true)
  if [ -n "$KAIROS_IP" ]; then
    HAS_KAIROS=$(${SSH_CMD} "sshpass -p kairos ssh ${SSH_OPTS} \
      -o ConnectTimeout=3 -o PreferredAuthentications=password -o PubkeyAuthentication=no \
      kairos@${KAIROS_IP} 'test -f /etc/kairos-release && echo yes'" 2>/dev/null || echo "no")

    if echo "$HAS_KAIROS" | grep -q "yes"; then
      echo "KAIROS_BOOTED at ${KAIROS_IP} after ${ELAPSED}s"
      exit 0
    fi
  fi

  # Log progress
  if echo "$NODE_STATUS" | grep -q "INSTALLING"; then
    echo "  NFS boot provisioning... (${ELAPSED}s)"
  elif echo "$NODE_STATUS" | grep -q "UP"; then
    echo "  Node UP, initialize/dd running... (${ELAPSED}s, IP: ${KAIROS_IP:-detecting})"
  elif echo "$NODE_STATUS" | grep -q "DOWN\|BOOTING"; then
    echo "  Node booting/rebooting... (${ELAPSED}s)"
  else
    echo "  Waiting for PXE... (${ELAPSED}s)"
  fi

  sleep 15
  ELAPSED=$((ELAPSED + 15))
done

echo "TIMEOUT after ${TIMEOUT}s"
exit 1
